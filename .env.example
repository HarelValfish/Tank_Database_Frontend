# ─── Frontend Environment Variables ──────────────────────────────
# Copy to ".env" if you want to point the app at a non-proxied API:
#   cp .env.example .env
#
# Leave this UNSET for local dev — vite.config.js proxies "/api" to
# http://localhost:5000 automatically. Only set it when the API lives
# on a different host (e.g. a deployed backend).
#
# VITE_API_URL=https://your-deployed-api.com

# ─── Local-only AI bulk importer ─────────────────────────────────
# Set to "true" ONLY in local dev to show the "AI Import" button.
# Leave UNSET / "false" for production builds — the feature must not ship.
# (The backend must also have ENABLE_AI_IMPORT=true, plus Ollama running.)
# Restart the Vite dev server after changing this.
# VITE_ENABLE_AI_IMPORT=true
